# Email Configuration
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_SECURE=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Database Configuration (MSSQL)
# Format: Server=localhost;Database=email_checker_db;User Id=sa;Password=your_password;Encrypt=false
DATABASE_URL="Server=localhost;Database=email_checker_db;User Id=sa;Password=your_password;Encrypt=false"

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# App Configuration
POLL_INTERVAL_MS=300000 # 5 minutes
